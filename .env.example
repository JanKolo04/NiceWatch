# Bootstrap env for the Docker stack. SMTP, alert recipient i progi alertów
# konfigurujesz w panelu (/settings) po pierwszym zalogowaniu — nie tutaj.
#
# Wygeneruj APP_KEY:
#   docker compose run --rm --no-deps app php artisan key:generate --show

APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_KEY=

# Port na hoście, pod którym wystawiony jest panel
NICEWATCH_HTTP_PORT=8080

# ---------- Pierwszy admin (auto-utworzony przy pierwszym `up`) ----------
# Konto seedowane jest idempotentnie — jeśli istnieje, seeder go zostawia.
# UWAGA: dla produkcji zmień hasło PRZED pierwszym `docker compose up`!
NICEWATCH_ADMIN_EMAIL=admin@nicewatch.local
NICEWATCH_ADMIN_PASSWORD=admin
NICEWATCH_ADMIN_NAME=Admin

# Opcjonalny dev mail catcher (Mailpit) — `docker compose --profile dev up -d`
MAILPIT_UI_PORT=8025
