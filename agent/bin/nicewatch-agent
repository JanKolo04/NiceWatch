#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoload = __DIR__ . '/../vendor/autoload.php';
if (! file_exists($autoload)) {
    fwrite(STDERR, "Run `composer install` in " . dirname(__DIR__) . " first.\n");
    exit(1);
}
require $autoload;

use NiceWatch\Agent\Command\PingCommand;
use NiceWatch\Agent\Command\RunCommand;
use Symfony\Component\Console\Application;

$app = new Application('nicewatch-agent', '0.1.0');
$app->add(new RunCommand());
$app->add(new PingCommand());
$app->run();
