# Bootstrap env dla wariantu ZA TRAEFIKIEM (docker-compose.traefik.yml).
# Skopiuj do .env i uzupełnij.
#
# Wygeneruj APP_KEY:
#   docker compose -f docker-compose.traefik.yml run --rm --no-deps app php artisan key:generate --show

APP_ENV=production
APP_DEBUG=false
APP_KEY=

# Domena pod którą Traefik wystawi NiceWatch. NICEWATCH_DOMAIN to sam host
# (do reguły routingu Traefika), APP_URL to pełny URL (Laravel + one-liner agenta).
# Muszą wskazywać na to samo.
NICEWATCH_DOMAIN=nicewatch.example.com
APP_URL=https://nicewatch.example.com

# TLS terminuje Traefik — cookies tylko po HTTPS.
SESSION_SECURE_COOKIE=true

# Pierwszy admin (puste hasło = losowe wypisane raz w `docker compose logs app`).
NICEWATCH_ADMIN_EMAIL=admin@example.com
NICEWATCH_ADMIN_PASSWORD=
NICEWATCH_ADMIN_NAME=Admin
